# ============================================
# AuraFit AI Backend Configuration
# ============================================

# Application Settings
APP_NAME=AuraFit AI
APP_VERSION=0.1.0
DEBUG=True

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=aurafit_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001

# Auth Configuration
AUTH_SECRET_KEY=aurafit_dev_secret_cambiar
AUTH_TOKEN_EXP_MINUTES=1440

# Gemini Configuration
IA_PROVIDER=gemini
IA_RESPONSE_MODE=ultra_pro
IA_AUTONOMOUS_MODE=True
IA_TESTING_MODE=False
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=2400
IA_ATTACHMENTS_MAX_MB=25
IA_FALLBACK_LOCAL=True

# Eden AI Configuration
EDEN_API_KEY=
EDEN_MODEL=@edenai
EDEN_ROUTER_CANDIDATES=
EDEN_TIMEOUT_SECONDS=60

# Qwen / OpenAI-compatible Configuration
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=qwen3-32b-instruct
QWEN_SUPPORTS_MULTIMODAL=False

# Premium multimodal generation (real image/video)
PREMIUM_MEDIA_ENABLED=True
PREMIUM_IMAGE_PROVIDER=openai
PREMIUM_VIDEO_PROVIDER=replicate
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
PREMIUM_IMAGE_RETRIES=2
REPLICATE_API_TOKEN=
REPLICATE_VIDEO_MODEL=kwaivgi/kling-v1.6-standard
REPLICATE_VIDEO_FALLBACK_MODELS=
PREMIUM_VIDEO_RETRIES=2
PREMIUM_VIDEO_POLL_SECONDS=2.0
PREMIUM_VIDEO_TIMEOUT_SECONDS=120

# RASA Configuration
RASA_WEBHOOK_URL=http://127.0.0.1:5005/webhooks/rest/webhook
RASA_TIMEOUT_SECONDS=20
