# ============================================
# AuraFit AI Backend Configuration
# ============================================
# Copy this file to .env and update values

# Application Settings
APP_NAME=AuraFit AI
APP_VERSION=0.1.0
DEBUG=True

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=aurafit_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001

# Auth Configuration
AUTH_SECRET_KEY=aurafit_dev_secret_cambiar
AUTH_TOKEN_EXP_MINUTES=1440

# Gemini Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
IA_FALLBACK_LOCAL=True

# RASA Configuration
RASA_WEBHOOK_URL=http://127.0.0.1:5005/webhooks/rest/webhook
RASA_TIMEOUT_SECONDS=20
